{
  "ignoreCommand": "[ \"$VERCEL_GIT_COMMIT_REF\" != \"dev\" ] && [ \"$VERCEL_GIT_COMMIT_REF\" != \"prod\" ]",
  "buildCommand": "pnpm turbo run build",
  "outputDirectory": "apps/web/dist",
  "installCommand": "pnpm install",
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/[...route]" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}